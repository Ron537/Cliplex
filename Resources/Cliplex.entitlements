<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No App Sandbox: a clipboard manager needs to observe the global
         pasteboard and synthesize keystrokes (Accessibility), which the
         sandbox forbids. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
